# Copy to tak-client-cert.env (gitignored) and fill in your values.
# Or export these variables in your shell before running the script.

# Required
TAK_SSH_HOST=your-k8s-node.tailnet-or-ip
TAK_SSH_USER=your-ssh-user
TAK_SERVER=tak.example.com

# Optional
TAK_CLIENT_PASS=your-pkcs12-password
TAK_CERT_GROUPS="__ANON__ YourTeamGroup"
# TAK_NAMESPACE=tak
# TAK_DEPLOY=tak-server
# TAK_CONTAINER=tak-api
# TAK_SECRET_NAME=tak-server-secrets
# TAK_SSH_OPTS=StrictHostKeyChecking=accept-new
# TAK_KUBECONFIG=
# TAK_KUBECTL=
