# Copy to config/sync-portfolio.conf and customize for your private source tree.
# Format for SCRUB_RULES: literal_substring|PLACEHOLDER (longest matches win)

RSYNC_EXCLUDES="
.git/
environments/local/
**/.env
**/.env.*
**/wg0.conf
!**/wg0.conf.example
scripts/tak-client-cert.env
scripts/*-atak-bundle/
scripts/*.p12
scripts/*.pem
**/__pycache__/
.venv/
node_modules/
"

# Order in file does not matter — sync-portfolio.sh sorts by length descending.
SCRUB_RULES="
# LAN nodes (add every static IP from your lab)
LAN_NODE_IP_SECONDARY|LAN_NODE_IP_SECONDARY
LAN_NODE_IP_PRIMARY|LAN_NODE_IP_PRIMARY
LAN_NODE_IP_EXAMPLE|LAN_NODE_IP_EXAMPLE
LAN_CIDR_PLACEHOLDER|LAN_CIDR_PLACEHOLDER

# Accounts and paths
GITHUB_ORG_PLACEHOLDER|GITHUB_ORG_PLACEHOLDER
LINUX_USER_PLACEHOLDER|LINUX_USER_PLACEHOLDER
/home/LINUX_USER_PLACEHOLDER|/home/LINUX_USER_PLACEHOLDER

# Application hosts (specific before generic suffix)
APP_JELLYFIN_HOST_PLACEHOLDER|APP_JELLYFIN_HOST_PLACEHOLDER
APP_GRAFANA_HOST_PLACEHOLDER|APP_GRAFANA_HOST_PLACEHOLDER
APP_ARGOCD_HOST_PLACEHOLDER|APP_ARGOCD_HOST_PLACEHOLDER
DOMAIN_SUFFIX_PLACEHOLDER|DOMAIN_SUFFIX_PLACEHOLDER

# WireGuard / VPS (optional — publish only if you want topology visible)
WG_HOMELAB_PEER_PLACEHOLDER|WG_HOMELAB_PEER_PLACEHOLDER
WG_VPS_PEER_PLACEHOLDER|WG_VPS_PEER_PLACEHOLDER

# Generic fallbacks (run after specific rules in built sed script)
@LAN_NODE_IP_PLACEHOLDER|@LAN_NODE_IP_PLACEHOLDER
LAN_IP_OCTET_PLACEHOLDER|LAN_IP_OCTET_PLACEHOLDER
"

# Extended regex; used by --verify after sync (must not appear in public tree).
FORBIDDEN_PATTERNS="
192\.168\.[0-9]{1,3}\.[0-9]{1,3}
GITHUB_ORG_PLACEHOLDER
LINUX_USER_PLACEHOLDER@
/home/LINUX_USER_PLACEHOLDER
\.homelab\.local
"
